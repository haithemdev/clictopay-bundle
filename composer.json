{
    "name": "hdev/clictopay-bundle",
    "description": "Ready-to-use Symfony Bundle for ClicToPay (SMT Tunisia) Payment Gateway. Supports multi-account, event-driven architecture, and built-in webhook handling.",
    "keywords": ["clictopay", "smt", "payment", "gateway", "tunisia", "symfony", "bundle"],
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "hdev",
            "email": "haithemdev@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/http-client": "^6.4|^7.0",
        "symfony/event-dispatcher": "^6.4|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/test-pack": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Hdev\\ClicToPayBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hdev\\ClicToPayBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*|7.*"
        },
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
